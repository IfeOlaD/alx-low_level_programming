#include <stdio.h>
#include "list.h"

/**
 * print_listint - prints all element of the listint list
 * @h: the pointer to head of the list
 * Return: the number of nodes
 */

size_t print_listint(const listint_t *h)
{
size_t count = 0;

while (h != NULL)
{
printf("%d\n", h->n);
h = h->next;
count++;
}

return (count);
}
