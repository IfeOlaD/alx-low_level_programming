#include "main.h"
#include <math.h>
#include <string.h>

/**
 * binary_to_uint - converts binary to positive int
 * @b: the pointer to the binary numbers
 * Return: the result, 0, or NULL
 */

unsigned int binary_to_uint(const char *b)
{
unsigned int result;
int len;
int a;
result = 0;
len = strlen(b);

if (b == NULL)
return (0);
for (a = 0; a < len; a++)
{
if (b[a] != '0' && b[a] != '1')
{
return (0);
}
    
result = result + (b[a] - '0') * pow(2, len -a -1);
}
return (result);
}
